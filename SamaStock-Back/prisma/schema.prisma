generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Product {
  id             Int      @id @default(autoincrement())
  supplier_id    Int      @default(0)
  supplier       Supplier @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  name           String
  description    String?
  quantity       Int
  purchasePrice  Float
  salePrice      Float
  alertThreshold Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  movements StockMovement[]
  sales     Sale[]
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  type      String
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  sales Sale[]
}

model Sale {
  id          Int     @id @default(autoincrement())
  productId   Int
  clientId    Int?
  quantity    Int
  unitPrice   Float
  totalAmount Float
  paidAmount  Float   @default(0)
  remaining   Float   @default(0)
  customer    String?

  note      String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  cash    Transaction[]
}

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  address   String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  product   Product[]

  @@map("suppliers")
}

//  Cash 

model Transaction {
  id Int @id @default(autoincrement())
  sale_id       Int?
  sale         Sale?          @relation(fields: [sale_id], references: [id], onDelete: NoAction)
  type          CashType
  label         String
  amount        Float
  paymentMethod PaymentMethod
  createdAt     DateTime?     @default(now())
  updatedAt     DateTime?     @updatedAt

  @@map("transactions")
}

// =========================== ENUMNS 

enum CashType {
  EXIT
  ENTRY
}

enum PaymentMethod {
  CASH
  WAVE
  ORANGE_MONEY
}
