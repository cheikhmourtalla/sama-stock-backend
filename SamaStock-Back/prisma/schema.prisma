generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Product {
  id            Int      @id @default(autoincrement())
  
  name          String
  description   String?
  quantity      Int      @default(0)
  purchasePrice Float
  salePrice     Float
  alertThreshold Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements StockMovement[]
  sales     Sale[]
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  type      String
  quantity  Int
  note      String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  sales Sale[]
}

model Sale {
  id          Int     @id @default(autoincrement())
  productId   Int
  clientId    Int?
  quantity    Int
  unitPrice   Float
  totalAmount Float
  paidAmount  Float   @default(0)
  remaining   Float   @default(0)
  customer    String?

  note      String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
}


model Supplier {
  id        Int      @id @default(autoincrement())
  // Relation product
nom       String
email     String   @unique
adresse   String?
entreprise String
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt


}

